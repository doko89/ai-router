# Anthropic Adapter Configuration
# Copy this file to .env and fill in your values

# OpenAI-compatible API Base URL
# For v1/chat/completions (default):
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
# For v1/responses (newer API):
# OPENAI_BASE_URL=https://api.openai.com/v1/responses

# API Key (required unless provided via the x-api-key request header)
OPENAI_API_KEY=your-api-key-here

# Host to bind the adapter to (default: 0.0.0.0)
HOST=0.0.0.0

# Port to bind the adapter to (default: 8000)
PORT=8000

# Tiktoken encoding used for count_tokens (default: cl100k_base for GPT-4/3.5)
TIKTOKEN_ENCODING=cl100k_base
